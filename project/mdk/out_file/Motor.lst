   91          void Dream_speed(void)
   92          {                                               
   93   1          uint16 tp_turn;
   94   1              int8 delta = (int8)(err_sum - Mid_Col);
   95   1          // 计算舵机偏离中值的程度
   96   1          if (Out_servo >  SERVO_CENTER)//左拐
   97   1          {
   98   2              tp_turn = Out_servo - SERVO_CENTER;
   99   2                      diff_left  = (int16)(- delta * diff_kp);
  100   2                      diff_right = (int16)( 0.76f *  delta * diff_kp);
  101   2          }
  102   1          else                        //右拐
  103   1          {
  104   2              tp_turn = SERVO_CENTER - Out_servo;
  105   2                      delta = -delta;   // 转为正偏差量 (Mid_Col - err_sum)
  106   2                      diff_left  = (int16)(   0.76f* delta * diff_kp);
  107   2                      diff_right = (int16)(-  delta * diff_kp);
  108   2          }
  109   1      
  110   1          // 限幅，防止超过最大转向量
  111   1          if (tp_turn > MAX_TURN)
  112   1          {
  113   2              tp_turn = MAX_TURN;
  114   2          }
  115   1      
  116   1          // 直道：tp_turn = 0        → tar_speed = MAX_SPEED
  117   1          // 弯道：tp_turn 越大      → tar_speed 越低
  118   1          // 最大转向：tp_turn=MAX_TURN → tar_speed = MIN_SPEED
  119   1          tar_speed = MAX_SPEED -
  120   1                      (uint32)(MAX_SPEED - MIN_SPEED) * tp_turn / MAX_TURN;
  121   1      }
