  266          void DMA_UART1_IRQHandler(void) interrupt DMA_UR1R_VECTOR
  267          {
  268   1          static vuint8 dwon_count = 0;
  269   1      
  270   1          if (DMA_UR1R_STA & 0x01) // 接收完成
  271   1          {
  272   2              DMA_UR1R_STA &= ~0x01;      // 清标志位
  273   2              uart_rx_start_buff(UART_1); // 设置下一次接收，务必保留
  274   2      
  275   2              // 程序自动下载
  276   2              if (uart_rx_buff[UART_1][0] == 0x7F)
  277   2              {
  278   3                  if (dwon_count++ > 20)
  279   3                  {
  280   4                      IAP_CONTR = 0x60;
  281   4                  }
  282   3              }
  283   2              else
  284   2              {
  285   3                  dwon_count = 0;
  286   3              }
  287   2      
  288   2              if (uart_rx_handlers[UART_1] != NULL)
  289   2              {
  290   3                  uart_rx_handlers[UART_1](uart_rx_buff[UART_1][0]);
  291   3              }
  292   2          }
  293   1      
  294   1          if (DMA_UR1R_STA & 0x02) // 数据丢弃
  295   1          {
  296   2              DMA_UR1R_STA &= ~0x02;      // 清标志位
  297   2              uart_rx_start_buff(UART_1); // 设置下一次接收，务必保留
  298   2              // 如果进入了这个中断，则代表UART的数据在没有取走之前被覆盖!
  299   2              // 如果进入了这个中断，则代表UART的数据在没有取走之前被覆盖!
  300   2              // 如果进入了这个中断，则代表UART的数据在没有取走之前被覆盖!
  301   2          }
  302   1      }
