   40          {
   41   1              uint8 i;
   42   1              volatile uint8 far *intf_reg = (volatile uint8 far *)(0x7efd10 + 0x00);//保存中断端口
   43   1              uint8 flags = *intf_reg;
   44   1              *intf_reg &= ~flags;
   45   1      
   46   1              for(i=0; i<8; i++)//查找中断
   47   1          {
   48   2              if(flags & (0x01 << i))
   49   2              {
   50   3                  gpio_int_irq_handlers[0x01][i]();
   51   3              }
   52   2          }
   53   1      }
