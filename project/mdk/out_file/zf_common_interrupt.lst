   38          //-------------------------------------------------------------------------------------------------------
             -------------
   39          // 函数简介     指定中断设置优先级
   40          // 参数说明     irqn            
   41          // 参数说明     priority        抢占式优先级 0到3，0为最低优先级，3为最高优先级
   42          // 返回参数     void
   43          // 使用示例     interrupt_set_priority( TIM5_IRQn, 3);
   44          //                       设置周期中断定时器0的优先级为3
   45          // 备注信息                              其余不能设置的，中断优先级全部为最低优先级0
   46          //-------------------------------------------------------------------------------------------------------
             -------------
   47          void interrupt_set_priority (irqn_type_enum irqn, uint8 priority)
   48          {
   49   1              if((irqn >> 4) == 0)
   50   1              {
   51   2                      IP  |= (priority & 0x01) << (irqn & 0x0F);
   52   2                      IPH |= ((priority >> 1) & 0x01) << (irqn & 0x0F);
C251 COMPILER V5.60.0,  zf_common_interrupt                                                02/07/26  22:43:54  PAGE 2   

   53   2              }
   54   1              else if((irqn >> 4) == 1)
   55   1              {
   56   2                      IP2  |= (priority & 0x01) << (irqn & 0x0F);
   57   2                      IP2H |= ((priority >> 1) & 0x01) << (irqn & 0x0F);
   58   2              }
   59   1              else if((irqn >> 4) == 2)
   60   1              {
   61   2      //              IP3  |= (priority & 0x01) << (irqn & 0x0F);
   62   2      //              IP3H |= ((priority >> 1) & 0x01) << (irqn & 0x0F);
   63   2              }
   64   1              else 
   65   1              {
   66   2                      switch (irqn)
   67   2                      {
   68   3                              case TIM5_IRQn: T6T5CFG &= ~(3<<1);   T6T5CFG |= priority << 1; break;
   69   3                              case TIM6_IRQn: T6T5CFG &= ~(3<<6);   T6T5CFG |= priority << 6;break;
   70   3                              case TIM7_IRQn: T8T7CFG &= ~(3<<1);   T8T7CFG |= priority << 1;break;
   71   3                              case TIM8_IRQn: T8T7CFG &= ~(3<<6);   T8T7CFG |= priority << 6;break;
   72   3                              case TIM9_IRQn: T10T9CFG &= ~(3<<1);  T10T9CFG |= priority << 1;break;
   73   3                              case TIM10_IRQn:T10T9CFG &= ~(3<<6);  T10T9CFG |= priority << 6;break;
   74   3                              case TIM17_IRQn:T18T17CFG &= ~(3<<1); T18T17CFG |= priority << 1;break;
   75   3                              case TIM18_IRQn:T18T17CFG &= ~(3<<6); T18T17CFG |= priority << 6;break;
   76   3      
   77   3                              case UART1_DMA_IRQn: DMA_UR1R_CFG &= ~(3<<2); DMA_UR1R_CFG |= priority << 2;break;
   78   3                              case UART2_DMA_IRQn: DMA_UR2R_CFG &= ~(3<<2); DMA_UR2R_CFG |= priority << 2;break;
   79   3                              case UART3_DMA_IRQn: DMA_UR3R_CFG &= ~(3<<2); DMA_UR3R_CFG |= priority << 2;break;
   80   3                              case UART4_DMA_IRQn: DMA_UR4R_CFG &= ~(3<<2); DMA_UR4R_CFG |= priority << 2;break;
   81   3                              case UART5_DMA_IRQn: DMA_UR5R_CFG &= ~(3<<2); DMA_UR5R_CFG |= priority << 2;break;
   82   3                              case UART6_DMA_IRQn: DMA_UR6R_CFG &= ~(3<<2); DMA_UR6R_CFG |= priority << 2;break;
   83   3                              case UART7_DMA_IRQn: DMA_UR7R_CFG &= ~(3<<2); DMA_UR7R_CFG |= priority << 2;break;
   84   3                              case UART8_DMA_IRQn: DMA_UR8R_CFG &= ~(3<<2); DMA_UR8R_CFG |= priority << 2;break;
   85   3      
   86   3                              case LCM_DMA_IRQn:DMA_LCM_CFG &= ~(3<<2); DMA_LCM_CFG |= priority << 2;break;
   87   3                              
   88   3                              case P0_INI_IRQ: //P0到P7共用2个字节控制中断优先级
   89   3                              case P1_INI_IRQ:
   90   3                              case P2_INI_IRQ: 
   91   3                              case P3_INI_IRQ: 
   92   3                              case P4_INI_IRQ: 
   93   3                              case P5_INI_IRQ: 
   94   3                              case P6_INI_IRQ: 
   95   3                              case P7_INI_IRQ: 
   96   3                                      if(priority / 2){PINIPH |= (0x01 << (irqn & 0x0f));}
   97   3                                      else{PINIPH &= ~(0x01 << (irqn & 0x0f));}
   98   3                                      if(priority % 2){PINIPL |= (0x01 << (irqn & 0x0f));}
   99   3                                      else{PINIPL |= (0x01 << (irqn & 0x0f));}
  100   3                                      break;
  101   3                              case P8_INI_IRQ: //P8到PB共用2个字节控制中断优先级
  102   3                              case P9_INI_IRQ: 
  103   3                              case PA_INI_IRQ: 
  104   3                              case PB_INI_IRQ: 
  105   3                                      if(priority / 2){PIN2IPH |= (0x01 << (irqn & 0x0f));}
  106   3                                      else{PIN2IPH &= ~(0x01 << (irqn & 0x0f));}
  107   3                                      if(priority % 2){PIN2IPL |= (0x01 << (irqn & 0x0f));}
  108   3                                      else{PIN2IPL |= (0x01 << (irqn & 0x0f));}
  109   3                                      break;
  110   3                      }
  111   2              }
  112   1      }
