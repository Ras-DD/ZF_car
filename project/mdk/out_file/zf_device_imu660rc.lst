                       //------------------------------------------------------------------------------------------------------
             --------------
                       //  @brief      НЁ№эSPIРҙТ»ёцbyte,Н¬Кұ¶БИЎТ»ёцbyte
                       //  @param      byte        ·ўЛНөДКэҫЭ
                       //  @return     uint8 edata       return ·ө»ШstatusЧҙМ¬
                       //  @since      v1.0
                       //  Sample usage:
                       //------------------------------------------------------------------------------------------------------
             --------------
                       static uint8 imu660rc_simspi_wr_byte(uint8 byte)
                       {
                               uint8 i;
                               for(i=0; i<8; i++)
                               {
                                       IMU660RC_SCK (0);
                                       IMU660RC_MOSI(byte&0x80);
C251 COMPILER V5.60.0,  zf_device_imu660rc                                                 02/07/26  22:43:58  PAGE 4   

                                       byte <<= 1;
                                       IMU660RC_SCK (1);
                                       byte |= IMU660RC_MISO;
                               }
                               IMU660RC_SCK (0);
                               return(byte);
                       }
                       
                       //------------------------------------------------------------------------------------------------------
             --------------
                       //  @brief      Ҫ«valРҙИлcmd¶ФУҰөДјДҙжЖчөШЦ·,Н¬Кұ·ө»ШstatusЧЦҪЪ
                       //  @param      cmd         ГьБоЧЦ
                       //  @param      val         ҙэРҙИлјДҙжЖчөДКэЦө
                       //  @since      v1.0
                       //  Sample usage:
                       //------------------------------------------------------------------------------------------------------
             --------------
                       static void imu660rc_simspi_w_reg_byte(uint8 cmd, uint8 val)
                       {
                               cmd |= IMU660RC_SPI_W;
                               imu660rc_simspi_wr_byte(cmd);
                               imu660rc_simspi_wr_byte(val);
                       }
               
               
                       //------------------------------------------------------------------------------------------------------
             --------------
                       //  @brief      Ҫ«valРҙИлcmd¶ФУҰөДјДҙжЖчөШЦ·
                       //  @param      cmd         ГьБоЧЦ
                       //  @param      val         ҙэРҙИлјДҙжЖчөДКэЦө
                       //  @since      v1.0
                       //  Sample usage:
                       //------------------------------------------------------------------------------------------------------
             --------------
                       static void imu660rc_simspi_w_reg_bytes(uint8 cmd, uint8 *dat_addr, uint32 len)
                       {
                               cmd |= IMU660RC_SPI_W;
                               imu660rc_simspi_wr_byte(cmd);
                               while(len--)
                               {
                                       imu660rc_simspi_wr_byte(*dat_addr++);
                               }
                       }
               
                       //------------------------------------------------------------------------------------------------------
             --------------
                       //  @brief      ¶БИЎcmdЛщ¶ФУҰөДјДҙжЖчөШЦ·
                       //  @param      cmd         ГьБоЧЦ
                       //  @param      *val        ҙжҙў¶БИЎөДКэҫЭөШЦ·
                       //  @param      num         ¶БИЎөДКэБҝ
                       //  @since      v1.0
                       //  Sample usage:
                       //------------------------------------------------------------------------------------------------------
             --------------
                       static void imu660rc_simspi_r_reg_bytes(uint8 cmd, uint8 *val, uint32 num)
                       {
                               cmd |= IMU660RC_SPI_R;
                               imu660rc_simspi_wr_byte(cmd);
                               while(num--)
                               {
                                       *val++ = imu660rc_simspi_wr_byte(0);
                               }
                       }
               
               
