             -------------
  311          static uint32 fp16_to_float(uint16 h)
  312          {
  313   1          uint32 f_sgn;
  314   1          uint16 h_exp;
  315   1          uint32 f_exp;
  316   1          uint32 f_sig;
  317   1          
  318   1          h_exp = (h & 0x7c00u);
  319   1          f_sgn = ((uint32)h & 0x8000u) << 16;
  320   1          switch (h_exp)
  321   1          {
  322   2              case 0x0000u:   // 0 or subnormal
  323   2              {
  324   3                  uint16 h_sig = (h & 0x03ffu);
  325   3                  // Signed zero
  326   3                  if (h_sig == 0)
  327   3                  {
  328   4                      return f_sgn;
  329   4                  }
  330   3                  // Subnormal
  331   3                  h_sig <<= 1;
  332   3                  while ((h_sig & 0x0400u) == 0)
  333   3                  {
  334   4                      h_sig <<= 1;
  335   4                      h_exp++;
  336   4                  }
  337   3                  f_exp = ((uint32)(127 - 15 - h_exp)) << 23;
  338   3                  f_sig = ((uint32)(h_sig & 0x03ffu)) << 13;
  339   3                  return f_sgn + f_exp + f_sig;
  340   3              }
  341   2              case 0x7c00u: // inf or NaN
  342   2              {
  343   3                  // All-ones exponent and a copy of the significand
  344   3                  return f_sgn + 0x7f800000u + (((uint32)(h & 0x03ffu)) << 13);
  345   3              }
  346   2              default: // normalized
  347   2              {
  348   3                  // Just need to adjust the exponent and shift
  349   3                  return f_sgn + (((uint32)(h & 0x7fffu) + 0x1c000u) << 13);
  350   3              }
