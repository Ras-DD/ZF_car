  392          static void quarternion_to_euler(float quat[4], float *roll, float *pitch, float *yaw)
  393          {
  394   1          float euler[3];
  395   1      
  396   1              float sqx = quat[0] * quat[0];
  397   1              float sqy = quat[1] * quat[1];
  398   1              float sqz = quat[2] * quat[2];
  399   1      
  400   1              euler[0] =  atan2(2.0f * (quat[1] * quat[3] + quat[0] * quat[2]), 1.0f - 2.0f * (sqy + sqx));
  401   1              euler[1] = -asin(2.0f * (quat[0] * quat[3] - quat[1] * quat[2]));
  402   1              euler[2] =  atan2(2.0f * (quat[0] * quat[1] + quat[2] * quat[3]), 1.0f - 2.0f * (sqx + sqz));
  403   1          
  404   1          // »Ў¶ИЧӘҪЗ¶И
  405   1          euler[0] = 180 * (euler[0]) / M_PI;
  406   1          euler[1] = 180 * (euler[1]) / M_PI;
  407   1          euler[2] = 180 * (euler[2]) / M_PI;
  408   1          
  409   1          // ҪЗ¶ИөчХы
  410   1          euler[2] = 0 > euler[2] ? euler[2] + 360 : euler[2];
  411   1          
  412   1          *roll   = euler[0];
C251 COMPILER V5.60.0,  zf_device_imu660rc                                                 02/07/26  22:43:58  PAGE 8   

  413   1          *pitch  = euler[1];
  414   1          *yaw    = euler[2];
  415   1      }
