  361          static void quarternion_normalize(float quat[4], uint16 *fp16)
  362          {
  363   1          float n = 0;
  364   1          float temp[4];
  365   1          
  366   1          *(uint32 *)(&temp[0]) = fp16_to_float(fp16[0]);
  367   1          *(uint32 *)(&temp[1]) = fp16_to_float(fp16[1]);
  368   1          *(uint32 *)(&temp[2]) = fp16_to_float(fp16[2]);
  369   1          *(uint32 *)(&temp[3]) = fp16_to_float(fp16[3]);
  370   1          
  371   1          n = temp[0] * temp[0] + temp[1] * temp[1] + temp[2] * temp[2] + temp[3] * temp[3];
  372   1          n = sqrt(n);
  373   1          
  374   1          if(n > 0.001f)  // ұЬГвіэТФҪУҪь0өДЦө
  375   1          {
  376   2              n = temp[3] < 0.0f ? -n : n;
  377   2              
  378   2              quat[0] = temp[1] / n;
  379   2              quat[1] = temp[2] / n;
  380   2              quat[2] = temp[0] / n;
  381   2              quat[3] = temp[3] / n;
  382   2          }
