  292   2              }
  293   1              
  294   1          return_state = ips200pro_send_buffer(temp, length, IPS200PRO_WAIT_TIME, NULL == buffer);
  295   1          if((0 == return_state) && (NULL != buffer) && (0 != buffer_length))
