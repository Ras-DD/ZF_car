  190          //-------------------------------------------------------------------------------------------------------
             -------------
  191          // 函数简介     屏幕等待函数
  192          // 参数说明     wait_time       等待时间
  193          // 返回参数     uint8           1：超时退出 0：未超时
  194          // 使用示例
  195          // 备注信息     内部使用，用户无需关心
  196          //-------------------------------------------------------------------------------------------------------
             -------------
  197          static uint8 ips200pro_wait_idle (uint32 wait_time)
  198          {
  199   1          wait_time = wait_time * 100;
  200   1      
  201   1          while(0 == IPS200PRO_INT() && (0 != wait_time))
  202   1          {
  203   2              func_soft_delay(1000);
  204   2              wait_time--;
  205   2          }
  206   1          return (!wait_time);
  207   1      }
  208          
  209          #if(1 == IPS200PRO_CRC_ENABLE)
               static uint8 ips200pro_calculate_crc8(uint8 *dat, uint32 length)
               {
                   uint8 i, crc = 0;
                   while(length--)
                   {
                       crc ^= *dat++;
                       for (i = 0; i < 8; i++)
                       {
                           crc = (crc & 0x80) ? ((crc << 1) ^ 0x07) : (crc <<= 1);
                       }
                   }
                   return crc;
               }
               #endif
