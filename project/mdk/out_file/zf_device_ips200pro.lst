  225          uint8 ips200pro_send_buffer(const void *buffer, uint32 length, uint32 time_out, uint8 end_flag)
  226          {
  227   1          uint8 return_state = 1;
  228   1      
  229   1          if(     ((0 == time_out) || (0 == ips200pro_wait_idle(time_out)))   // 等待未超时
  230   1              &&  (IPS200PRO_SPI_LENGTH >= length)                            // 数据量未超过限制
  231   1              &&  (NULL != buffer))                                           // 指针不为空
  232   1          {
  233   2              IPS200PRO_CS(0);
  234   2              ips200pro_write_8bit_data_spi_array((const uint8 *)buffer, length);
  235   2              if(1 == end_flag)
  236   2              {
  237   3                  IPS200PRO_CS(1);
  238   3              }
  239   2              return_state = 0;
  240   2          }
  241   1          return return_state;
  242   1      }
