  498          //-------------------------------------------------------------------------------------------------------
             -------------
  499          void tft180_show_gray_image (uint16 x, uint16 y, const uint8 *image, uint16 width, uint16 height, uint16 
             -dis_width, uint16 dis_height, uint8 threshold)
  500          {
  501   1          uint32 i = 0, j = 0;
  502   1          uint16 color ,temp ;
  503   1          uint16 data_buffer[TFT180_LEN];
  504   1          const uint8 *image_temp;
  505   1      
  506   1          // Из№ыіМРтФЪКдіцБЛ¶ПСФРЕПў ІўЗТМбКҫіцҙнО»ЦГФЪХвАп
  507   1          // ДЗГҙТ»°гКЗЖБД»ПФКҫөДКұәті¬№эЖБД»·ЦұжВК·¶О§БЛ
  508   1          zf_assert(x < tft180_x_max);
  509   1          zf_assert(y < tft180_y_max);
  510   1          zf_assert(NULL != image);
  511   1      
  512   1          TFT180_CS(0);
  513   1          tft180_set_region(x, y, x + dis_width - 1, y + dis_height - 1);             // ЙиЦГПФКҫЗшУт
  514   1      
  515   1          for(j = 0; j < dis_height; j ++)
  516   1          {
  517   2              image_temp = image + j * height / dis_height * width;                   // ЦұҪУ¶Ф image ІЩЧч»б Ha
             -rdfault ФЭКұІ»ЦӘөАОӘКІГҙ
  518   2              for(i = 0; i < dis_width; i ++)
  519   2              {
  520   3                  temp = *(image_temp + i * width / dis_width);                       // ¶БИЎПсЛШөг
  521   3                  if(threshold == 0)
  522   3                  {
  523   4                      color = (0x001f & ((temp) >> 3)) << 11;
  524   4                      color = color | (((0x003f) & ((temp) >> 2)) << 5);
  525   4                      color = color | (0x001f & ((temp) >> 3));
  526   4                      data_buffer[i] = (color);
  527   4                  }
  528   3                  else if(temp < threshold)
  529   3                  {
  530   4                      data_buffer[i] = (RGB565_BLACK);
  531   4                  }
  532   3                  else
  533   3                  {
  534   4                      data_buffer[i] = (RGB565_WHITE);
  535   4                  }
  536   3              }
  537   2              tft180_write_16bit_data_arry(data_buffer, dis_width);
  538   2          }
  539   1          
  540   1          TFT180_CS(1);
  541   1      }
